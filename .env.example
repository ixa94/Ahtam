# ============================================
# Пароль для страницы /admin (обязательно!)
# ============================================
ADMIN_PASSWORD=change_me_please

# ============================================
# Email — уведомления о новых заявках
# ============================================
# Для mail.ru:
#   Host: smtp.mail.ru
#   Port: 465 (SSL)
#   User: ваш_адрес@mail.ru
#   Pass: пароль от почты (или пароль приложения, если включена 2FA)
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=ваш_адрес@mail.ru
SMTP_PASS=ваш_пароль
SMTP_TO=

# ============================================
# MAX мессенджер (опционально, если появится бот)
# ============================================
# MAX_BOT_TOKEN=YOUR_MAX_BOT_TOKEN
# MAX_CHAT_ID=YOUR_MAX_USER_ID

# ============================================
# Supabase — ТОЛЬКО если нужны статьи из базы
# Без этого сайт работает на JSON-файлах
# ============================================
# NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_PUBLIC_ANON_KEY
# SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
